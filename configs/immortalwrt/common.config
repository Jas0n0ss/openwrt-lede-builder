# ============================================
# LEDE 通用配置 + PassWall 完整依赖
# ============================================

# ===== 完美解决 libustream 冲突问题（老版本与新版本全覆盖） =====
CONFIG_PACKAGE_libustream-openssl20201210=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_libustream-mbedtls20201210=n
CONFIG_PACKAGE_libustream-mbedtls=n

# LEDE 基础设置
CONFIG_DEVEL=y
CONFIG_KERNEL_BUILD_USER="OpenWrt"
CONFIG_KERNEL_BUILD_DOMAIN="Local"
CONFIG_CCACHE=y
CONFIG_USE_MUSL=y
CONFIG_USE_SSTRIP=y

# ===== 基础组件 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
# LuCI 中文：base/firewall + 各插件见 configs/snippets/luci-zh-cn.config
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_openssl=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_iperf3=y

# ===== 文件系统支持 =====
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-usb-storage=y

# ===== 网络支持 =====
# dnsmasq: use target DEFAULT_PACKAGES (do not force dnsmasq-full — Kconfig cycle on LEDE)
CONFIG_PACKAGE_firewall=y

# ============================================
# PassWall 核心配置
# ============================================
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_Including_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_Including_V2ray=y
CONFIG_PACKAGE_luci-app-passwall_Including_Xray=y

# ===== PassWall 核心依赖 =====
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_geoview=y

# ===== PassWall 协议支持 =====
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
# CONFIG_PACKAGE_naiveproxy is not set
CONFIG_PACKAGE_shadowsocks-libev-ss-local=y
CONFIG_PACKAGE_shadowsocks-libev-ss-redir=y
CONFIG_PACKAGE_shadowsocksr-libev=y
CONFIG_PACKAGE_simple-obfs=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_v2ray-plugin=y
CONFIG_PACKAGE_xray-plugin=y
CONFIG_PACKAGE_shadow-tls=y

# ===== 基础库依赖 =====
CONFIG_PACKAGE_libev=y
CONFIG_PACKAGE_libsodium=y
CONFIG_PACKAGE_pcre2=y
CONFIG_PACKAGE_libpcre2=y
CONFIG_PACKAGE_libudns=y
CONFIG_PACKAGE_libcares=y
CONFIG_PACKAGE_libcurl=y
CONFIG_PACKAGE_libxml2=y
CONFIG_PACKAGE_libunistring=y

# ===== Boost 库依赖 =====
CONFIG_PACKAGE_boost=y
CONFIG_PACKAGE_boost-system=y
CONFIG_PACKAGE_boost-program_options=y
CONFIG_PACKAGE_boost-date_time=y

# ===== 工具依赖 =====
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_bc=y
CONFIG_PACKAGE_pciutils=y
CONFIG_PACKAGE_lm-sensors=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_yq=y

# ===== LuCI 依赖 =====
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# ===== 禁用冲突的包 =====
# CONFIG_PACKAGE_vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-fchomo is not set
# CONFIG_PACKAGE_luci-theme-alpha is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set

# CONFIG_PACKAGE_luci-app-fchomo is not set
# CONFIG_PACKAGE_luci-theme-alpha is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_containerd is not set
# CONFIG_PACKAGE_luci-app-unblockneteasemusic is not set
# CONFIG_PACKAGE_libselinux is not set
# CONFIG_PACKAGE_libsepol is not set

CONFIG_PACKAGE_irqbalance=y

# Custom plugins: merged from configs/custom-plugins.config at build time
