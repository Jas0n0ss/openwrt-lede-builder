
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_redmi-router-ax6000=y

CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=512

CONFIG_TARGET_ROOTFS_SQUASHFS=y

CONFIG_DEVEL=y
CONFIG_CCACHE=y

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y

CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_dnsmasq-full=y

CONFIG_PACKAGE_wpad-openssl=y

CONFIG_PACKAGE_kmod-mt7915-firmware=y
CONFIG_PACKAGE_kmod-mt7915e=y

CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y

CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_v2dat=y

CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-flowoffload=y

CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_luci-app-fullconenat=y

CONFIG_PACKAGE_AdGuardHome=y

CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y

CONFIG_PACKAGE_luci-theme-argon=y

CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_luci-proto-ipv6=y

CONFIG_PACKAGE_irqbalance=y

# 安全禁用 Docker / 容器
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_containerd is not set
# CONFIG_PACKAGE_runc is not set

# 避免冲突组件
# CONFIG_PACKAGE_luci-app-dae is not set
# CONFIG_PACKAGE_luci-app-daed is not set
# CONFIG_PACKAGE_fchomo is not set
# CONFIG_PACKAGE_luci-app-openclash is not set

CONFIG_ALL_NONSHARED=y

