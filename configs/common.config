CONFIG_DEVEL=y
CONFIG_KERNEL_BUILD_USER="OpenWrt"
CONFIG_KERNEL_BUILD_DOMAIN="Local"
CONFIG_CCACHE=y
CONFIG_USE_MUSL=y
CONFIG_USE_SSTRIP=y

# ===== SSL/TLS Configuration =====
# Use MbedTLS only to avoid conflicts with OpenSSL
CONFIG_LIBUSTREAM_MBEDTLS=y
# CONFIG_LIBUSTREAM_OPENSSL is not set

# ===== Build Optimization =====
CONFIG_PARALLEL_BUILD=y

# 基础组件
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_openssl=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_vim=y
CONFIG_PACKAGE_htop=y

# PassWall 及其依赖
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_Including_Hysteria=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_v2ray-geodata=y
CONFIG_PACKAGE_geoview=y

# 其他插件
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-arpbind=y

# 禁用问题包
# CONFIG_PACKAGE_vlmcsd is not set
# CONFIG_PACKAGE_luci-app-vlmcsd is not set
# CONFIG_PACKAGE_luci-app-fchomo is not set
# CONFIG_PACKAGE_luci-theme-alpha is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
