# ============================================
# Custom plugins (see README)
# ============================================

# PassWall Hysteria
CONFIG_PACKAGE_hysteria=y

# MosDNS (+ LuCI deps: jsonfilter, v2ray-geoip, v2ray-geosite)
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_v2dat=y
CONFIG_PACKAGE_jsonfilter=y
CONFIG_PACKAGE_luci-i18n-mosdns-zh-cn=y

# TurboACC (no shortcut-fe OFFLOADING — kmod-fast-classifier not on all targets)
CONFIG_PACKAGE_luci-app-turboacc=y
# CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOADING is not set
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_NFT_FULLCONE=y
# kmod-tcp-bbr / kmod-nft-* : pulled by luci-app-turboacc DEPENDS only (never CONFIG_PACKAGE_kmod-*=y here)

# TTYD (from packages + luci feeds)
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_libwebsockets-full=y
CONFIG_PACKAGE_libuv=y
CONFIG_PACKAGE_libjson-c=y

# ARP bind
CONFIG_PACKAGE_luci-app-arpbind=y

# Aurora theme
CONFIG_PACKAGE_luci-theme-aurora=y
